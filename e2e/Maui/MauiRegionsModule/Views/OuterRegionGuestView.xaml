<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:prism="http://prismlibrary.com"
             x:Class="MauiRegionsModule.Views.OuterRegionGuestView"
             x:DataType="viewmodels:OuterRegionGuestViewModel"
             xmlns:viewmodels="clr-namespace:MauiRegionsModule.ViewModels">
  <VerticalStackLayout Padding="8" Spacing="8">
    <Label Text="Outer region guest (GitHub #3332)"
           FontAttributes="Bold" />
    <Label Text="Inner region is below; it is navigated when this guest receives region navigation (see outer view model)." />
    <ContentView x:Name="InnerRegionHostView"
                 prism:RegionManager.RegionName="InnerRegion"
                 MinimumHeightRequest="160"
                 BackgroundColor="#220000FF" />
  </VerticalStackLayout>
</ContentView>

<Page
    x:Class="Playground.Module.Views.DialogLabView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
  <ScrollViewer Padding="24">
    <StackPanel Spacing="16" MaxWidth="640">
      <TextBlock Text="Dialog lab" FontSize="28" FontWeight="SemiBold" />
      <TextBlock TextWrapping="Wrap" IsTextSelectionEnabled="True">
        Prism IDialogService with Uno DialogWindow. NotificationDialog shows parameters; ConfirmDialog returns OK or Cancel.
      </TextBlock>
      <Button Content="Show notification dialog" Command="{Binding ShowNotificationCommand}" />
      <Button Content="Show confirm dialog" Command="{Binding ShowConfirmCommand}" />
      <TextBlock Text="{Binding LastResult}" TextWrapping="Wrap" />
    </StackPanel>
  </ScrollViewer>
</Page>
